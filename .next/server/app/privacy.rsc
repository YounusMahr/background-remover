5:["$","section",null,{"className":"legal-section","children":[["$","h2",null,{"children":"Our Advertising Partners"}],["$","p",null,{"children":"Some of the advertisers on our site may use cookies and web beacons. Our advertising partners include:"}],["$","ul",null,{"children":["$","li",null,{"children":[["$","strong",null,{"children":"Google AdSense:"}]," Their privacy policies can be reviewed at ",["$","a",null,{"href":"https://policies.google.com/technologies/ads","target":"_blank","rel":"noopener noreferrer","children":"https://policies.google.com/technologies/ads"}],"."]}]}],["$","p",null,{"children":"These third-party ad servers or ad networks use technologies like cookies, JavaScript, or Web Beacons that are used in their respective advertisements and links that appear on BGCleaner, which are sent directly to users' browsers. They automatically receive your IP address when this occurs. These technologies are used to measure the effectiveness of their advertising campaigns and/or to personalize the advertising content that you see on websites that you visit."}],["$","p",null,{"children":"Note that BGCleaner has no access to or control over these cookies that are used by third-party advertisers."}]]}]
6:["$","section",null,{"className":"legal-section","children":[["$","h2",null,{"children":"Third Party Privacy Policies"}],["$","p",null,{"children":"BGCleaner's Privacy Policy does not apply to other advertisers or websites. Thus, we are advising you to consult the respective Privacy Policies of these third-party ad servers for more detailed information. It may include their practices and instructions about how to opt-out of certain options."}],["$","p",null,{"children":"You can choose to disable cookies through your individual browser options. To know more detailed info about cookie management with specific web browsers, it can be found at the browsers' respective websites."}]]}]
7:["$","section",null,{"className":"legal-section","children":[["$","h2",null,{"children":"CCPA Privacy Rights (Do Not Sell My Personal Information)"}],["$","p",null,{"children":"Under the CCPA, among other rights, California consumers have the right to:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Request that a business that collects a consumer's personal data disclose the categories and specific pieces of personal data that a business has collected about consumers."}],["$","li",null,{"children":"Request that a business delete any personal data about the consumer that a business has collected."}],["$","li",null,{"children":"Request that a business that sells a consumer's personal data, not sell the consumer's personal data."}]]}],["$","p",null,{"children":"If you make a request, we have one month to respond to you. If you would like to exercise any of these rights, please contact us at contact@bgcleaner.online."}]]}]
8:["$","section",null,{"className":"legal-section","children":[["$","h2",null,{"children":"GDPR Data Protection Rights"}],["$","p",null,{"children":"We would like to make sure you are fully aware of all of your data protection rights. Every user is entitled to the following:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"The right to access:"}]," You have the right to request copies of your personal data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to rectification:"}]," You have the right to request that we correct any information you believe is inaccurate."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to erasure:"}]," You have the right to request that we erase your personal data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to restrict processing:"}]," You have the right to request that we restrict the processing of your personal data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to object to processing:"}]," You have the right to object to our processing of your personal data, under certain conditions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to data portability:"}]," You have the right to request that we transfer the data that we have collected to another organization, or directly to you, under certain conditions."]}]]}],["$","p",null,{"children":"If you make a request, we have one month to respond to you. If you would like to exercise any of these rights, please contact us."}]]}]
9:["$","section",null,{"className":"legal-section","children":[["$","h2",null,{"children":"Children's Information"}],["$","p",null,{"children":"Another part of our priority is adding protection for children while using the internet. We encourage parents and guardians to observe, participate in, and/or monitor and guide their online activity."}],["$","p",null,{"children":"BGCleaner does not knowingly collect any Personal Identifiable Information from children under the age of 13. If you think that your child provided this kind of information on our website, we strongly encourage you to contact us immediately and we will do our best efforts to promptly remove such information from our records."}]]}]
