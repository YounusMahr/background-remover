# Hostinger & LiteSpeed Compatible .htaccess Rules
<IfModule mod_rewrite.c>
    Options -Indexes +FollowSymLinks
    RewriteEngine On
    RewriteBase /

    # 1. Sitemap XML
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # 2. Blog Index
    RewriteRule ^blog/?$ blog.php [L,QSA]

    # 3. Single Blog Post (/blog/{slug} -> post.php?slug={slug})
    RewriteRule ^blog/([a-zA-Z0-9\-]+)/?$ post.php?slug=$1 [L,QSA]

    # 4. Standalone Pages & Admin Panel
    RewriteRule ^admin/?$ admin.php [L,QSA]
    RewriteRule ^about/?$ about.php [L,QSA]
    RewriteRule ^contact/?$ contact.php [L,QSA]
    RewriteRule ^privacy/?$ privacy.php [L,QSA]
    RewriteRule ^terms/?$ terms.php [L,QSA]
    RewriteRule ^cookies/?$ cookies.php [L,QSA]
    RewriteRule ^disclaimer/?$ disclaimer.php [L,QSA]
</IfModule>

ErrorDocument 404 /404.php
