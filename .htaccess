ErrorDocument 404 /404.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 0. 301 the ugly .php URLs to their clean equivalents (SEO consolidation).
    #    THE_REQUEST matches only the original browser request, so the internal
    #    rewrites below never trigger this and no redirect loop occurs.
    RewriteCond %{THE_REQUEST} \s/+(about|contact|privacy|terms|cookies|disclaimer|blog)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+post\.php\?slug=([a-zA-Z0-9\-]+) [NC]
    RewriteRule ^ /blog/%1? [R=301,L]

    # 1. Sitemap XML
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # 2. Blog Index
    RewriteRule ^blog/?$ blog.php [L,QSA]

    # 3. Single Blog Post (/blog/{slug} -> post.php?slug={slug})
    RewriteRule ^blog/([a-zA-Z0-9\-]+)/?$ post.php?slug=$1 [L,QSA]

    # 4. Standalone Pages (/about, /contact, /privacy, /terms, /cookies, /disclaimer)
    RewriteRule ^about/?$ about.php [L,QSA]
    RewriteRule ^contact/?$ contact.php [L,QSA]
    RewriteRule ^privacy/?$ privacy.php [L,QSA]
    RewriteRule ^terms/?$ terms.php [L,QSA]
    RewriteRule ^cookies/?$ cookies.php [L,QSA]
    RewriteRule ^disclaimer/?$ disclaimer.php [L,QSA]
</IfModule>
